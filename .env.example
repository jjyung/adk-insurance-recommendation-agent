# 1. Vertex AI 相關設定

## 是否使用 Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=1
## Google Cloud project ID
GOOGLE_CLOUD_PROJECT=your-project-id-here
## Google Cloud 區域
GOOGLE_CLOUD_LOCATION=us-central1
# 2. 使用 API 金鑰的方式連接 Google GenAI 時需要提供金鑰 (當GOOGLE_GENAI_USE_VERTEXAI=0時需要提供)
GOOGLE_API_KEY=your-api-key-here
# 使用服務帳戶金鑰連接 Google GenAI 時需要提供金鑰檔案路徑
GOOGLE_APPLICATION_CREDENTIALS=your-service-account-key-file.json
# [Deployment]系統環境設定---------------------------------
## Artifact Registry 儲存庫名稱
ARTIFACT_REPOSITORY=insurance-agent-repo

## 觀測性 (Observability) 設定
## 是否將追蹤資料 (Traces) 傳送至 Google Cloud Trace (適合雲端部署環境)
ENABLE_CLOUD_TRACING=0
## 是否將日誌資料 (Logs) 傳送至 Google Cloud Logging (適合雲端部署環境)
ENABLE_CLOUD_LOGGING=0
## OpenTelemetry 服務名稱，會顯示在 Cloud Trace / Logging 的來源標籤中
OTEL_SERVICE_NAME=insurance-recommendation-agent
## 是否記錄完整的 LLM 提示詞與回應內容 (預設為 false 僅記錄 metadata，在 PoC 階段可設為 true)
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=false

# Agent 設定
ADK_APP_NAME=app

## [Database] Session 資料庫 URI，使用 PostgreSQL 儲存會話資料
ADK_SESSION_DB_URI=postgresql+asyncpg://user:password@localhost:5432/insurance
# ADK_MEMORY_MODE=in_memory (已廢棄，專案統一使用 DatabaseSessionService 進行持久化儲存)

## [模型設定] gemini-3.1-flash-lite-preview & gemini-live-2.5-flash-preview-native-audio-09-2025
MODEL_NAME=gemini-2.5-flash
LIVE_MODEL_NAME=gemini-live-2.5-flash-preview-native-audio-09-2025

## [MCP] MCPToolBox 伺服器設定
TOOLBOX_PORT=5001
TOOLBOX_SERVER_URL=http://127.0.0.1:5001

## AUDIT 功能
AUDIT_LOG_ENABLED=1
AUDIT_DB_PATH=postgresql+asyncpg://user:password@localhost:5432/insurance
AUDIT_RETENTION_DAYS=365
AUDIT_HASH_SALT=change-me-in-production
PII_REDACTION_ENABLED=1

# [Auth] 設定
NEXT_PUBLIC_API_URL=http://localhost:8080
FASTAPI_BASE_URL=http://127.0.0.1:8080
FASTAPI_BASE_URL_DOCKER=http://backend:8080
JWT_SECRET=your-jwt-secret-here
# openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# [Terraform] 設定 (dev/staging/prod)
 ENV_NAME=dev
 GITHUB_OWNER=your-github-username
 GITHUB_REPO_NAME=insurance-recommendation-agent