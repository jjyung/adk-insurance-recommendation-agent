# Deployment
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data based configuration files.
*.tfvars
*.tfvars.json

# Allow .tfvars.example files to be tracked
!*.tfvars.example

# Ignore override files as they are usually used to override resources locally and so are individual based
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files you do wish to add to version control using wildcard pattern
# !example_override.tf

# Include plugin cache directory
.terraform.lock.hcl


# Playwright
.playwright/
.playwright-cli/

# issues
/issues/**

# Infrastructure configuration
**/*.tfvars
!**/*.tfvars.example
deployments/cmds/**
deployment_metadata.json
# Deployment artifacts
app/app_utils/.requirements.txt
*.tfbackend

# Docs
# docs/**
docs/raw/

# Graphify
graphify-out/*
!graphify-out/graph.json
!graphify-out/graph.html

# graphify-visualization
/graphify-out/*

# plans
docs/plans/**