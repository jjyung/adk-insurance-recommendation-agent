# --- 專案基本設定 ---
project_name         = "insurance-agent"
# project_id      = "your-project-id" # 通常由 Makefile 自動注入
# region              = "us-central1"     # 通常由 Makefile 自動注入

# --- AI 模型設定 ---
model_name           = "gemini-2.5-flash"
live_model_name      = "gemini-live-2.5-flash-preview-native-audio-09-2025"

# --- 功能開關 (1 為開啟, 0 為關閉) ---
enable_telemetry     = "1"
enable_audit_log     = "1"
enable_pii_redaction = "1"

# --- 映像檔設定 (通常由 Makefile 自動注入，手動指定時取消註解) ---
# backend_image       = "gcr.io/..."
# toolbox_image       = "gcr.io/..."
# frontend_image      = "gcr.io/..."
# deployment/terraform/staging/terraform.tfvars 範例
# 請根據您的實際 GCP 專案與 GitHub 資訊修改以下內容
